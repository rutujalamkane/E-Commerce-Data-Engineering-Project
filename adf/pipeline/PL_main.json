{
	"name": "PL_main",
	"properties": {
		"activities": [
			{
				"name": "exe-local-bronze",
				"type": "ExecutePipeline",
				"dependsOn": [],
				"policy": {
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"pipeline": {
						"referenceName": "PL_localFile_to_AdlsBronze",
						"type": "PipelineReference"
					},
					"waitOnCompletion": true,
					"parameters": {
						"p_file_name": {
							"value": "@pipeline().parameters.p_file_name",
							"type": "Expression"
						}
					}
				}
			},
			{
				"name": "exe-raw-to-bronze",
				"type": "ExecutePipeline",
				"dependsOn": [
					{
						"activity": "exe-local-bronze",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"pipeline": {
						"referenceName": "PL_adlsRaw_to_adlsBronze",
						"type": "PipelineReference"
					},
					"waitOnCompletion": true,
					"parameters": {
						"p_filename": {
							"value": "@pipeline().parameters.p_filename",
							"type": "Expression"
						}
					}
				}
			},
			{
				"name": "exe-git-to-bronze",
				"type": "ExecutePipeline",
